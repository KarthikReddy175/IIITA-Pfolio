<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Drives – Admin | IIITApfolio</title>
    <link rel="stylesheet" href="/styles/admin_manage.css">
    <link rel="stylesheet" href="https://unicons.iconscout.com/release/v4.0.0/css/line.css">
</head>
<body>
    <div class="page-nav">
        <a href="/" class="nav-brand"><i class="uil uil-university"></i> IIITApfolio</a>
        <div class="nav-links">
            <a href="/adminlog" class="nav-btn"><i class="uil uil-tachometer-fast-alt"></i> Dashboard</a>
            <a href="/adminlog#companies" class="nav-btn"><i class="uil uil-building"></i> Companies</a>
            <a href="/adminlog#students" class="nav-btn"><i class="uil uil-users-alt"></i> Students</a>
            <a href="/alogout" class="nav-btn logout"><i class="uil uil-signout"></i> Logout</a>
        </div>
    </div>

    <div class="admin-container">
        <div class="page-header">
            <div>
                <h1><i class="uil uil-briefcase"></i> Placement Drives</h1>
                <p class="header-subtitle">Create, manage and track placement drives</p>
            </div>
            <button class="btn-primary" onclick="toggleForm()">
                <i class="uil uil-plus"></i> Create Drive
            </button>
        </div>

        <!-- Create Drive Form -->
        <div id="addForm" class="form-card" style="display:none">
            <div class="form-card-header">
                <h3><i class="uil uil-plus-circle"></i> Create New Placement Drive</h3>
                <button class="form-close-btn" onclick="toggleForm()">&times;</button>
            </div>
            <% if(companies.length === 0){ %>
            <div class="form-note-box">
                <i class="uil uil-exclamation-triangle"></i>
                No companies found. <a href="/adminlog#companies">Add a company</a> first before creating a drive.
            </div>
            <% } else { %>
            <form action="/admin/drives" method="post">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Company *</label>
                        <select name="company_id" required>
                            <option value="" disabled selected>Select Company</option>
                            <% for(var ci=0; ci<companies.length; ci++){ %>
                            <option value="<%= companies[ci].id %>"><%= companies[ci].name %></option>
                            <% } %>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Role *</label>
                        <input type="text" name="role" placeholder="e.g. Software Engineer" required>
                    </div>
                    <div class="form-group">
                        <label>Package (LPA)</label>
                        <input type="text" name="package_lpa" placeholder="e.g. 25 LPA">
                    </div>
                    <div class="form-group">
                        <label>Status</label>
                        <select name="status">
                            <option value="upcoming">Upcoming</option>
                            <option value="active">Active</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Min CGPA</label>
                        <input type="number" step="0.01" min="0" max="10" name="min_cgpa" value="7.00" placeholder="0.00">
                    </div>
                    <div class="form-group">
                        <label>Max Backlogs Allowed</label>
                        <input type="number" min="0" name="max_backlogs" value="0">
                    </div>
                    <div class="form-group">
                        <label>Eligible Branches</label>
                        <div class="checkbox-group">
                            <label class="checkbox-label">
                                <input type="checkbox" name="eligible_branches" value="IT" checked> IT
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" name="eligible_branches" value="ECE" checked> ECE
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" name="eligible_branches" value="IT-BI" checked> IT-BI
                            </label>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Drive Date</label>
                        <input type="date" name="drive_date">
                    </div>
                    <div class="form-group">
                        <label>Last Date to Apply</label>
                        <input type="date" name="last_date_apply">
                    </div>
                    <div class="form-group full-width">
                        <label>Description</label>
                        <textarea name="description" rows="3" placeholder="Job description, requirements, etc."></textarea>
                    </div>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn-primary"><i class="uil uil-check"></i> Create Drive</button>
                    <button type="button" class="btn-secondary" onclick="toggleForm()">Cancel</button>
                </div>
            </form>
            <% } %>
        </div>

        <!-- Drives List -->
        <% if(drives.length === 0){ %>
        <div class="empty-state">
            <i class="uil uil-briefcase"></i>
            <h3>No Placement Drives</h3>
            <p>Create your first placement drive to start accepting applications.</p>
        </div>
        <% } else { %>
        <div class="drives-grid">
            <% for(var i=0; i<drives.length; i++){ var d = drives[i]; %>
            <div class="drive-card-v2">
                <div class="drive-card-v2-top">
                    <div class="drive-status-badge status-<%= d.status %>"><%= d.status %></div>
                    <div class="drive-actions-top">
                        <form action="/admin/drives/status" method="post" style="display:inline">
                            <input type="hidden" name="id" value="<%= d.id %>">
                            <select name="status" onchange="this.form.submit()" class="status-select-sm">
                                <option value="upcoming" <%= d.status === 'upcoming' ? 'selected' : '' %>>Upcoming</option>
                                <option value="active" <%= d.status === 'active' ? 'selected' : '' %>>Active</option>
                                <option value="completed" <%= d.status === 'completed' ? 'selected' : '' %>>Completed</option>
                                <option value="cancelled" <%= d.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                            </select>
                        </form>
                    </div>
                </div>
                <div class="drive-card-v2-body">
                    <div class="drive-company-name"><%= d.company_name %></div>
                    <div class="drive-role"><%= d.role %></div>
                    <div class="drive-info-grid">
                        <div class="drive-info-item">
                            <i class="uil uil-money-bill"></i>
                            <span><%= d.package_lpa || 'Not disclosed' %></span>
                        </div>
                        <div class="drive-info-item">
                            <i class="uil uil-users-alt"></i>
                            <span><%= d.applicant_count %> applicants</span>
                        </div>
                        <div class="drive-info-item">
                            <i class="uil uil-calendar-alt"></i>
                            <span><%= d.drive_date ? new Date(d.drive_date).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) : 'TBD' %></span>
                        </div>
                        <% if(d.last_date_apply){ %>
                        <div class="drive-info-item">
                            <i class="uil uil-clock"></i>
                            <span>Deadline: <%= new Date(d.last_date_apply).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></span>
                        </div>
                        <% } %>
                    </div>
                    <div class="drive-criteria-tags">
                        <span class="criteria-tag">CGPA &ge; <%= d.min_cgpa %></span>
                        <span class="criteria-tag">Backlogs &le; <%= d.max_backlogs %></span>
                        <span class="criteria-tag"><%= d.eligible_branches %></span>
                    </div>
                    <% if(d.description){ %>
                    <p class="drive-desc"><%= d.description %></p>
                    <% } %>
                </div>
                <div class="drive-card-v2-footer">
                    <a href="/admin/drives/<%= d.id %>/applicants" class="btn-secondary">
                        <i class="uil uil-users-alt"></i> Applicants (<%= d.applicant_count %>)
                    </a>
                    <form action="/admin/drives/delete" method="post" style="display:inline" onsubmit="return confirm('Delete this drive and all its applications?')">
                        <input type="hidden" name="id" value="<%= d.id %>">
                        <button type="submit" class="btn-danger-sm"><i class="uil uil-trash-alt"></i> Delete</button>
                    </form>
                </div>
            </div>
            <% } %>
        </div>
        <% } %>
    </div>

    <script>
    function toggleForm(){
        var f = document.getElementById('addForm');
        f.style.display = f.style.display === 'none' ? 'block' : 'none';
    }
    </script>
</body>
</html>
