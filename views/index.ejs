<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IIITApfolio – Student Portfolio Platform</title>
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="https://unicons.iconscout.com/release/v4.0.0/css/line.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <nav class="landing-nav">
        <a href="/" class="nav-brand">
            <img src="/images/IIITA_Logo.png" alt="logo">
            <span>IIITApfolio</span>
        </a>
        <div class="nav-actions">
            <a href="/signup" class="nav-link">Student Login</a>
            <a href="/adminsignup" class="nav-link">Admin Login</a>
            <a href="/review" class="nav-link-outline">Review Us</a>
        </div>
    </nav>

    <main class="hero">
        <div class="hero-content">
            <div class="hero-badge">
                <img src="/images/IIITA_Logo.png" alt="IIIT Allahabad Logo" class="hero-badge-logo"> IIIT Allahabad
            </div>
            <h1>Your Portfolio,<br><span>Your Future.</span></h1>
            <p>Build, manage, and showcase your academic and professional portfolio. Track placement drives and land your dream opportunity.</p>
            <div class="search-box">
                <form action="/search" method="post" class="search-form">
                    <i class="uil uil-search"></i>
                    <input type="search" placeholder="Search student by email..." name="id" required>
                    <button type="submit">Search</button>
                </form>
            </div>
            <div class="hero-stats">
                <div class="hero-stat">
                    <i class="uil uil-users-alt"></i>
                    <span>Student Portfolios</span>
                </div>
                <div class="hero-stat">
                    <i class="uil uil-building"></i>
                    <span>Placement Drives</span>
                </div>
                <div class="hero-stat">
                    <i class="uil uil-shield-check"></i>
                    <span>Admin Verified</span>
                </div>
            </div>
        </div>
        <div class="hero-visual">
            <img src="/images/Group63.svg" alt="hero" class="hero-img">
            <div class="hero-blob"></div>
        </div>
    </main>
</body>
</html>
